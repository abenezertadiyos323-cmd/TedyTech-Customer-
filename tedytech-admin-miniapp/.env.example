# Convex Backend URL
# Get this from your Convex dashboard or use the deployment URL from your Convex project
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Demo mode (default: false — real data)
# Set to "true" only when you want hardcoded demo data (e.g. UI preview without a backend).
# VITE_DEMO_MODE=false

# Admin Telegram User ID
# Set ADMIN_CHAT_ID in the Convex dashboard environment variables (NOT here).
# This value must never be exposed in frontend env vars (VITE_* prefix is public).
# See: https://docs.convex.dev/production/environment-variables
